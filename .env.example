# Binance (use chaves da testnet em TRADING_MODE=testnet)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Brain (Replicate): digest completo opcional; se omitido, usa o digest padrão em brain.py.
# REPLICATE_MODEL_VERSION=anthropic/claude-3.5-sonnet:35821a9d383c4b453e7937119561937e1ba61318f7069324e976693a61f23a31

# Next.js dashboard (frontend/) — mesma instância Supabase; chave anon pública (não use service_role no browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — Project Settings > API
SUPABASE_URL=
# Chave service_role (Project Settings → API). Pode usar SUPABASE_KEY no .env.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=

# SPOT | FUTURES — SHORT só em FUTURES. Se definido, tem prioridade sobre Supabase `config`.
TRADING_MODE=FUTURES
# Par de negociação (aceita ETHUSDC; normalizado internamente para CCXT)
SYMBOL=ETHUSDC

# Abertura LIMIT + chase (futuros LONG / spot compra): espera por fill, depois cancela e reabre (padrão 15s × 3)
# AURIC_CHASE_TIMEOUT_S=15
# AURIC_CHASE_MAX_ROUNDS=3
# SHORT (futuros): chase mais agressivo — mercado em queda rápida (padrão 8s × 6 rondas)
# AURIC_CHASE_SHORT_TIMEOUT_S=8
# AURIC_CHASE_SHORT_MAX_ROUNDS=6
# Realização parcial 50% (ROI 0,8%): market (default) ou ioc (LIMIT IOC agressivo)
# AURIC_PARTIAL_TP_EXEC=market

# Execução (spot)
TRADE_QUOTE_USDC=20
TRADE_BASE_ETH=0.01
# Se > 0, main repete em loop
LOOP_SECONDS=0

# Smart Money APIs
COINMARKETCAP_API_KEY=0d8533f654914fee8caa25e638368c33
COINAPI_KEY=8218fd0f-9593-4175-87bc-7fb56fd439bc

# Redis atomic lock (anti-spam de ordens concorrentes)
REDIS_URL=redis://localhost:6379/0
# TTL em segundos para lock de envio de ordem (SET NX EX)
AURIC_ORDER_LOCK_TTL_S=5
