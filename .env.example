# Binance (use chaves da testnet em TRADING_MODE=testnet)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Ex.: meta/meta-llama-3-8b-instruct ou outro modelo de texto
REPLICATE_MODEL=meta/meta-llama-3-8b-instruct

# Supabase — Project Settings > API
SUPABASE_URL=
# Chave service_role (Project Settings → API). Pode usar SUPABASE_KEY no .env.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=

# testnet | paper | live
TRADING_MODE=testnet
# Par de negociação CCXT
SYMBOL=ETH/USDT

# Execução (spot)
TRADE_QUOTE_USDT=20
TRADE_BASE_ETH=0.01
# Se > 0, main repete em loop
LOOP_SECONDS=0
